generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PRODUCT_ADMIN
  ADMIN
}

enum Store {
  REMA_1000
  KIWI
  SPAR
  MENY
  COOP_EXTRA
  COOP_OBS
  COOP_PRIX
  BUNNPRIS
  ODA
}

enum PriceUnit {
  PER_UNIT
  PER_KG
}

model Product {
  id           String        @id @default(cuid())
  barcode      String?       @unique
  pluCode      String?       @unique
  name         String
  brand        String?
  imageUrl     String?
  weightG      Int?          // weight in grams, e.g. 400 for a 400g product
  volumeMl     Int?          // volume in millilitres, e.g. 1000 for 1l product
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String?
  createdBy    User?         @relation(fields: [createdById], references: [id])
  priceReports PriceReport[]
}

model PriceReport {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  store        Store
  price        Int       // in øre, e.g. 2999 = 29,99 kr
  priceUnit    PriceUnit @default(PER_UNIT)
  isOnSale     Boolean   @default(false)
  regularPrice Int?      // in øre, populated when isOnSale is true
  reportedAt   DateTime  @default(now())
  reportedById String?
  reportedBy   User?     @relation(fields: [reportedById], references: [id])

  @@index([productId, store, reportedAt])
}

// NextAuth models
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(USER)
  accounts      Account[]
  sessions      Session[]
  priceReports  PriceReport[]
  products      Product[]
  createdAt     DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
